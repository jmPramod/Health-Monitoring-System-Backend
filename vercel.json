{
  "version": 2,
  "builds": [
    {
      "src": "./src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["./dist/**", "./node_modules/swagger-ui-dist/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/src/index.ts" },
    { "src": "/(.*)", "dest": "/src/index.ts" }
  ]
}
